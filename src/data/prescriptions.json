{
  "prescriptions": [
    {
      "id": "mahuang-tang",
      "name": "麻黄汤",
      "category": "解表剂",
      "syndrome": "风寒表实证",
      "composition": [
        {
          "herb": "麻黄",
          "role": "君",
          "dosage": "三两",
          "effect": "宣肺解表，发汗散寒"
        },
        {
          "herb": "桂枝",
          "role": "臣",
          "dosage": "二两",
          "effect": "解肌发表，温通经脉"
        },
        {
          "herb": "杏仁",
          "role": "佐",
          "dosage": "七十个",
          "effect": "降利肺气，助麻黄平喘"
        },
        {
          "herb": "甘草",
          "role": "使",
          "dosage": "一两（炙）",
          "effect": "调和诸药"
        }
      ],
      "effect": "发汗解表，宣肺平喘",
      "indication": "外感风寒表实证。恶寒发热，头身疼痛，无汗而喘，脉浮紧",
      "contraindication": "表虚自汗、外感风热、阴虚盗汗者禁用",
      "formula_song": "麻黄汤中用桂枝，杏仁甘草四般施；发热恶寒头项痛，无汗而喘服之宜。",
      "decoction_method": "先煎麻黄去沫，后入诸药",
      "key_differentiation": "无汗是关键鉴别点"
    },
